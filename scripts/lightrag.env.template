# LightRAG Environment
# Copy to scripts/lightrag.env and fill in OMNIROUTE_API_KEY + GEMINI_API_KEY.
# NEVER commit lightrag.env to git (it's in .gitignore).
#
# LightRAG uses OmniRoute for extraction/summarization and Gemini/OpenRouter for
# embeddings. DeepSeek can be an LLM reserve behind OmniRoute, but it cannot
# provide embeddings.

# ── LLM: OmniRoute light ─────────────────────────────────────────────────────
# DeepSeek reserve is handled inside OmniRoute when DEEPSEEK_API_KEY is present
# in /opt/openclaw/omniroute.env and synced with:
#   OPENCLAW_HOST=deploy@<server-host> ./scripts/sync-omniroute-deepseek-provider.sh
# LightRAG still calls the stable `light` model.
LLM_BINDING=openai
LLM_MODEL=light
LLM_BINDING_API_KEY=<your-omniroute-api-key>
LLM_BINDING_HOST=http://omniroute:20129/v1
LLM_MAX_TOKEN_SIZE=32768

# ── Embeddings: Gemini ────────────────────────────────────────────────────────
# DeepSeek has no embeddings endpoint; use a funded embeddings-capable provider.
EMBEDDING_BINDING=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_BINDING_API_KEY=<your-gemini-api-key>
EMBEDDING_BINDING_HOST=https://generativelanguage.googleapis.com
EMBEDDING_DIM=3072
EMBEDDING_MAX_TOKEN_SIZE=2048

# ── Storage: file-based (no DB needed on CX23) ───────────────────────────────
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage

# ── Rate limiting ────────────────────────────────────────────────────────────
MAX_PARALLEL_INSERT=1
MAX_ASYNC=1
TIMEOUT=180

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=9621
CORS_ORIGINS=http://127.0.0.1
LIGHTRAG_WORKING_DIR=/app/data
WEBUI_TITLE=BeнькаMemory
