# LightRAG Environment
# Copy to scripts/lightrag.env and fill in GEMINI_API_KEY.
# NEVER commit lightrag.env to git (it's in .gitignore).
#
# Get free API key: https://aistudio.google.com/app/apikey
# One key covers both LLM and embeddings.

# ── LLM: Google Gemini Flash Lite ────────────────────────────────────────────
# gemini-2.5-flash-lite — stable for LightRAG extraction; gemini-2.0-flash is
# no longer available to some new Gemini API projects.
LLM_BINDING=gemini
LLM_MODEL=gemini-2.5-flash-lite
LLM_BINDING_API_KEY=<your-gemini-api-key>
LLM_BINDING_HOST=https://generativelanguage.googleapis.com
LLM_MAX_TOKEN_SIZE=32768

# ── Embeddings: Gemini ────────────────────────────────────────────────────────
# Same API key, no extra provider needed
EMBEDDING_BINDING=gemini
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_BINDING_API_KEY=<your-gemini-api-key>
EMBEDDING_BINDING_HOST=https://generativelanguage.googleapis.com
EMBEDDING_DIM=3072
EMBEDDING_MAX_TOKEN_SIZE=2048

# ── Storage: file-based (no DB needed on CX23) ───────────────────────────────
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage

# ── Rate limiting ────────────────────────────────────────────────────────────
MAX_PARALLEL_INSERT=1
MAX_ASYNC=1
TIMEOUT=180

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=9621
CORS_ORIGINS=http://127.0.0.1
LIGHTRAG_WORKING_DIR=/app/data
WEBUI_TITLE=BeнькаMemory
