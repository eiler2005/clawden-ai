# LightRAG Environment
# Copy to scripts/lightrag.env and fill in DEEPSEEK_API_KEY + WIKI_IMPORT_TOKEN.
# NEVER commit lightrag.env to git (it's in .gitignore).
#
# LightRAG currently uses direct DeepSeek for extraction/summarization after the
# OmniRoute light route timed out, and uses wiki-import's local OpenAI-compatible
# embeddings endpoint to avoid Gemini/OpenRouter quota failures.

# ── LLM: direct DeepSeek fallback ─────────────────────────────────────────────
# Preferred policy is OmniRoute first, then DeepSeek. The live deployment uses
# direct DeepSeek for this hop while OmniRoute light returns bridge timeouts.
LLM_BINDING=openai
LLM_MODEL=deepseek-chat
LLM_BINDING_API_KEY=<your-deepseek-api-key>
LLM_BINDING_HOST=https://api.deepseek.com/v1
LLM_MAX_TOKEN_SIZE=32768

# ── Embeddings: wiki-import local fallback ────────────────────────────────────
# DeepSeek has no embeddings endpoint. Gemini/OpenRouter can be restored later
# when paid quota is available; this local endpoint keeps LightRAG functional.
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=local/hash-embedding-3072
EMBEDDING_BINDING_API_KEY=<your-wiki-import-token>
EMBEDDING_BINDING_HOST=http://wiki-import:8095/v1
EMBEDDING_DIM=3072
EMBEDDING_MAX_TOKEN_SIZE=8192
EMBEDDING_TOKEN_LIMIT=8192
EMBEDDING_SEND_DIM=false
EMBEDDING_BATCH_NUM=16
CHUNK_SIZE=1200
CHUNK_OVERLAP_SIZE=100

# ── Storage: file-based (no DB needed on CX23) ───────────────────────────────
LIGHTRAG_KV_STORAGE=JsonKVStorage
LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage

# ── Rate limiting ────────────────────────────────────────────────────────────
MAX_PARALLEL_INSERT=1
MAX_ASYNC=1
TIMEOUT=180

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=9621
CORS_ORIGINS=http://127.0.0.1
LIGHTRAG_WORKING_DIR=/app/data
WEBUI_TITLE=BeнькаMemory
