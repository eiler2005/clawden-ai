# Local-only access and environment notes
LOCAL_ACCESS.md
CLAUDE.local.md
*.local.md
*.private.md
.claude/settings.local.json

# macOS
.DS_Store

# Editor
.vscode/
.idea/

# Temporary notes
tmp/
scratch/
*.log

# Never commit copied secrets
secrets/
*.pem
*.key
*.token

# LightRAG env (contains API keys)
scripts/lightrag.env

# Bot-managed runtime files (daily notes, auto-generated)
workspace/memory/[0-9]*.md
workspace/memory/archive/
workspace/raw/*
!workspace/raw/.gitkeep

# Local session context
LOCAL_*.md

# Personal profile files (real name, phone, email, family, clients)
workspace/USER.md
workspace/MEMORY.md
workspace/SOUL.md

# OmniRoute secrets (contains JWT secrets, API keys)
omniroute.env
