# Telethon Digest runtime environment.
# Copy to /opt/openclaw/telethon.env on the server and fill real values there.

# Use App api_id and App api_hash from my.telegram.org → API development tools.
TELEGRAM_API_ID=<telegram-app-api-id>
TELEGRAM_API_HASH=<telegram-app-api-hash>
TELEGRAM_PHONE=<telegram-phone-e164>

TELEGRAM_BOT_TOKEN=<openclaw-telegram-bot-token>
DIGEST_SUPERGROUP_ID=<supergroup-chat-id>
DIGEST_TOPIC_ID=<telegram-digest-message-thread-id>

OMNIROUTE_API_KEY=<omniroute-api-key>
LIGHTRAG_URL=http://lightrag:9621
OBSIDIAN_OUTPUT_DIR=/app/obsidian
DIGEST_CRON_BRIDGE_TOKEN=replace-with-long-random-token
