ARG OPENCLAW_BASE_IMAGE=ghcr.io/openclaw/openclaw:2026.6.9-slim
FROM ${OPENCLAW_BASE_IMAGE}

ARG DEBIAN_MIRROR=https://mirror.yandex.ru

USER root
RUN sed -i "s|http://deb.debian.org|${DEBIAN_MIRROR}|g" /etc/apt/sources.list.d/debian.sources \
    && apt-get update \
    && apt-get install -y --no-install-recommends iproute2 \
    && rm -rf /var/lib/apt/lists/*
RUN node -e 'const fs=require("fs"); const old="gpt-5."+4; const mini=old+"-mini"; const miniName="GPT-5."+4+"-Mini"; const catalog="/app/extensions/codex/provider-catalog.ts"; let txt=fs.readFileSync(catalog,"utf8"); const block=new RegExp(`\\n  \\{\\n    id: "${mini}",\\n    model: "${mini}",\\n    displayName: "${miniName}",\\n    description: "Smaller frontier agentic coding model\\\\.",\\n    inputModalities: \\\\["text", "image"\\\\],\\n    supportedReasoningEfforts: \\\\["low", "medium", "high", "xhigh"\\\\],\\n  \\},`,"g"); txt=txt.replace(block,""); fs.writeFileSync(catalog,txt); const provider="/app/extensions/codex/provider.ts"; txt=fs.readFileSync(provider,"utf8"); const modern=new RegExp(`lower === "gpt-5\\\\.5" \\\\|\\\\| lower === "${old}" \\\\|\\\\| lower === "${mini}" \\\\|\\\\| lower === "gpt-5\\\\.2"`,"g"); txt=txt.replace(modern,"lower === \"gpt-5.5\" || lower === \"gpt-5.2\""); fs.writeFileSync(provider,txt);'
RUN node -e 'const fs=require("fs"); const patches=[["/app/dist/probe-DiRWp0_u.js","enabled: opts.isolatedIngress?.enabled ?? true,","enabled: opts.isolatedIngress?.enabled ?? process.env.OPENCLAW_TELEGRAM_ISOLATED_INGRESS !== \"0\","],["/app/extensions/telegram/src/monitor.ts","enabled: opts.isolatedIngress?.enabled ?? true,","enabled: opts.isolatedIngress?.enabled ?? process.env.OPENCLAW_TELEGRAM_ISOLATED_INGRESS !== \"0\","]]; for (const [file,from,to] of patches) { let txt=fs.readFileSync(file,"utf8"); if (!txt.includes(from)) throw new Error(`telegram isolated ingress patch target not found in ${file}`); txt=txt.replace(from,to); fs.writeFileSync(file,txt); }'
USER node
