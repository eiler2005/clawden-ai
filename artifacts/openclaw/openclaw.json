{
  "gateway": {
    "mode": "local",
    "auth": {
      "allowTailscale": false,
      "rateLimit": {}
    },
    "trustedProxies": ["<docker-bridge-gateway-ip>"],
    "allowRealIpFallback": false
  },
  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 1,
    "sessionRetention": "24h",
    "runLog": {
      "maxBytes": "2mb",
      "keepLines": 2000
    }
  },
  "tools": {
    "profile": "coding",
    "exec": {
      "security": "deny",
      "ask": "always"
    },
    "fs": {
      "workspaceOnly": true
    },
    "elevated": {
      "enabled": false
    },
    "web": {
      "search": {
        "enabled": true,
        "provider": "duckduckgo",
        "maxResults": 5,
        "cacheTtlMinutes": 15,
        "openaiCodex": {
          "enabled": true,
          "mode": "cached",
          "contextSize": "high",
          "userLocation": {
            "country": "RU",
            "timezone": "Europe/Moscow"
          }
        }
      }
    }
  },
  "logging": {
    "redactSensitive": "tools"
  },
  "discovery": {
    "mdns": {
      "mode": "off"
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "memory": {
    "citations": "auto"
  },
  "browser": {
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": false
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "openai-codex/gpt-5.4",
        "fallbacks": [
          "omniroute/medium",
          "omniroute/smart",
          "omniroute/light"
        ]
      },
      "memorySearch": {
        "enabled": true,
        "provider": "gemini",
        "model": "gemini-embedding-001",
        "extraPaths": ["/opt/obsidian-vault/wiki"],
        "cache": {
          "enabled": true,
          "maxEntries": 50000
        },
        "remote": {
          "batch": {
            "enabled": true,
            "concurrency": 1,
            "wait": false
          }
        },
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3,
            "candidateMultiplier": 2,
            "mmr": {
              "enabled": false
            }
          }
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "botToken": "<telegram-bot-token>",
      "allowFrom": ["<owner-telegram-user-id>"],
      "groupAllowFrom": ["<owner-telegram-user-id>"],
      "groups": {
        "*": {
          "requireMention": true
        },
        "<ops-supergroup-chat-id>": {
          "requireMention": false,
          "groupPolicy": "open"
        },
        "<family-chat-id>": {
          "requireMention": true,
          "groupPolicy": "allowlist"
        },
        "<sandbox-chat-id>": {
          "requireMention": false,
          "groupPolicy": "allowlist"
        }
      },
      "groupPolicy": "allowlist",
      "streaming": {
        "mode": "partial"
      }
    }
  },
  "auth": {
    "profiles": {
      "openai-codex:default": {
        "provider": "openai-codex",
        "mode": "oauth"
      }
    },
    "order": {
      "openai-codex": ["openai-codex:default"]
    }
  }
}
