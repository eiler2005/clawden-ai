# OmniRoute environment — deploy to /opt/openclaw/omniroute.env
# NEVER commit the real file (gitignored). This example is safe for git.
#
# Generate secrets before first deploy:
#   JWT_SECRET:                openssl rand -base64 48
#   API_KEY_SECRET:            openssl rand -hex 32
#   STORAGE_ENCRYPTION_KEY:    openssl rand -hex 32

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=<generate: openssl rand -base64 48>
API_KEY_SECRET=<generate: openssl rand -hex 32>
STORAGE_ENCRYPTION_KEY=<generate: openssl rand -hex 32>
STORAGE_ENCRYPTION_KEY_VERSION=v1
INITIAL_PASSWORD=<choose-a-strong-password>
REQUIRE_API_KEY=true
ALLOW_API_KEY_REVEAL=false

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=20128
API_PORT=20129
API_HOST=0.0.0.0
INSTANCE_NAME=omniroute-hetzner
STORAGE_DRIVER=sqlite
SQLITE_MAX_SIZE_MB=512

# BASE_URL must be localhost during OAuth bootstrap (via SSH tunnel).
# After all providers are authenticated, this value is not critical.
BASE_URL=http://localhost:20128
NEXT_PUBLIC_BASE_URL=http://localhost:20128

# ── Provider API keys (no OAuth needed) ───────────────────────────────────────
# OpenRouter: register at openrouter.ai → Dashboard → API Keys → Create
OPENROUTER_API_KEY=<your-openrouter-api-key>

# ── OAuth providers (complete via SSH tunnel, see docs/03-operations.md) ──────
# Codex CLI: same OpenAI account used in OpenClaw (OAuth flow in dashboard)
# Kiro:      AWS Builder ID (free at aws.amazon.com/developer)
# Qoder:     qoder.ai (OAuth, gives Kimi + Qwen + DeepSeek)
# Gemini CLI: Google OAuth (same Google account already used for LightRAG)
# No extra env vars needed — all stored in omniroute-data volume after auth
