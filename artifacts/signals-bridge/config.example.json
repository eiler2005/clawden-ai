{
  "timezone": "Europe/Moscow",
  "scheduler": {
    "tick_seconds": 300,
    "cleanup_interval_seconds": 3600
  },
  "default_poll_interval_seconds": 300,
  "event_retention_days": 14,
  "delivery": {
    "topic_name": "signals",
    "mode": "mini_batch"
  },
  "last30days": {
    "enabled": true,
    "schedule_expr": "0 7 * * *",
    "timezone": "Europe/Moscow",
    "preset_id": "world-radar-v1",
    "mode": "compact",
    "telegram": {
      "topic_name": "last30daysTrend",
      "topic_id": 0
    },
    "obsidian": {
      "root": "Last30Days"
    },
    "max_items": 10,
    "query_bundle": [
      "OpenAI Anthropic Google DeepMind xAI Nvidia Apple Microsoft product launches AI research breakthroughs",
      "AI policy regulation antitrust government tech industry economy inflation tariffs geopolitics",
      "open source developer tools MCP protocol agents GitHub trending repos infrastructure frameworks",
      "machine learning research papers models benchmarks reasoning agents multimodal academic",
      "startup funding rounds acquisitions mergers venture capital unicorns IPO deals exits",
      "robotics autonomous vehicles space biotech semiconductors hardware frontier science",
      "content platforms creator economy streaming social media viral culture internet trends",
      "semiconductors chips supply chain trade war Taiwan defense cybersecurity national security"
    ],
    "platform_sources": {
      "reddit": {
        "mode": "rss",
        "feeds": [
          "worldnews", "technology", "science", "Futurology",
          "economy", "geopolitics", "artificial", "OutOfTheLoop"
        ]
      },
      "hn": {
        "feeds": ["frontpage", "ask", "show"]
      },
      "github": {
        "repos": [
          "openai/openai-python", "anthropics/anthropic-sdk-python",
          "modelcontextprotocol/servers", "microsoft/autogen",
          "langchain-ai/langchain", "ollama/ollama"
        ],
        "trending": true
      },
      "youtube": {
        "search_terms": [
          "AI news week", "tech industry analysis", "world events explained"
        ]
      },
      "bluesky": {
        "starter_packs": ["ai-researchers", "tech-journalists"]
      }
    }
  },
  "rule_files": [
    "rules/*.local.json"
  ],
  "sources": {
    "email": [
      {
        "id": "email-market-alerts",
        "kind": "email",
        "enabled": true,
        "inbox_ref": "alerts@example.com",
        "poll_interval_seconds": 300,
        "bootstrap_lookback_minutes": 720,
        "lag_grace_minutes": 15,
        "max_message_pages": 5,
        "message_page_size": 100
      }
    ],
    "telegram": [
      {
        "id": "telegram-market-chat-a",
        "kind": "telegram",
        "enabled": true,
        "chat_id": -1001111111111,
        "chat_name": "Example Market Chat A",
        "poll_interval_seconds": 300,
        "overlap_grace_minutes": 15,
        "message_limit": 80
      },
      {
        "id": "telegram-market-chat-b",
        "kind": "telegram",
        "enabled": true,
        "chat_id": -1002222222222,
        "chat_name": "Example Market Chat B",
        "poll_interval_seconds": 300,
        "overlap_grace_minutes": 15,
        "message_limit": 80
      }
    ],
    "web": [
      {
        "id": "web-tradingview-comments",
        "kind": "web",
        "enabled": false,
        "poll_interval_seconds": 300,
        "url": "https://www.tradingview.com",
        "note": "Reserved for future scraping rules."
      }
    ]
  },
  "rule_sets": []
}
