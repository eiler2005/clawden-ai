# Copy to /opt/signals-bridge/signals.env and fill real values there.

SIGNALS_BRIDGE_TOKEN=<generated-bridge-token>
TELEGRAM_BOT_TOKEN=<telegram-bot-token>
SIGNALS_SUPERGROUP_ID=<ops-supergroup-chat-id>
SIGNALS_TOPIC_ID=<topic-id-signals>
SIGNALS_TIMEZONE=Europe/Moscow
LAST30DAYS_ENABLED=1

TELEGRAM_API_ID=<telegram-api-id>
TELEGRAM_API_HASH=<telegram-api-hash>
TELEGRAM_PHONE=<telegram-phone-for-telethon-auth>

AGENTMAIL_API_KEY=<agentmail-api-key>

OMNIROUTE_URL=http://omniroute:20129/v1/chat/completions
OMNIROUTE_API_KEY=<omniroute-api-key>
OMNIROUTE_MODEL=light
OMNIROUTE_TIMEOUT_SECONDS=45
OMNIROUTE_MAX_TOKENS=500
OMNIROUTE_TEMPERATURE=0.1

SCRAPECREATORS_API_KEY=
BRAVE_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
AUTH_TOKEN=
CT0=
BSKY_HANDLE=
BSKY_APP_PASSWORD=
LAST30DAYS_TIMEOUT_SECONDS=420
LAST30DAYS_LOOKBACK_DAYS=30

SIGNALS_BRIDGE_PORT=8093
REDIS_URL=redis://integration-bus-redis:6379
