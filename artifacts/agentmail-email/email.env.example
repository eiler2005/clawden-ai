# AgentMail inbox-email runtime environment.
# Copy to /opt/agentmail-email/email.env on the server and fill real values there.

AGENTMAIL_API_KEY=<agentmail-api-key>
AGENTMAIL_INBOX_REF=<agentmail-inbox-id-or-address>

TELEGRAM_BOT_TOKEN=<openclaw-telegram-bot-token>
EMAIL_DIGEST_SUPERGROUP_ID=<ops-supergroup-chat-id>
EMAIL_DIGEST_TOPIC_ID=<topic-id-inbox-email>

OPENCLAW_EXEC_CONTAINER=openclaw-openclaw-gateway-1
OPENCLAW_AGENT_ID=main
OPENCLAW_AGENT_FALLBACK_ID=main
OPENCLAW_AGENT_THINKING=medium
OPENCLAW_AGENT_TIMEOUT_SECONDS=900

REDIS_URL=redis://integration-bus-redis:6379
EMAIL_BRIDGE_PORT=8092
EMAIL_BRIDGE_TOKEN=replace-with-long-random-token
