# AgentMail inbox-email runtime environment.
# Copy to /opt/agentmail-email/email.env on the server and fill real values there.

AGENTMAIL_API_KEY=<agentmail-api-key>
AGENTMAIL_INBOX_REF=<agentmail-inbox-id-or-address>
AGENTMAIL_API_TIMEOUT_SECONDS=30
AGENTMAIL_MAX_MESSAGE_PAGES=5
AGENTMAIL_MESSAGE_PAGE_SIZE=100
AGENTMAIL_TEXT_EXCERPT_LIMIT=2400
AGENTMAIL_PREVIEW_LIMIT=420

TELEGRAM_BOT_TOKEN=<openclaw-telegram-bot-token>
EMAIL_DIGEST_SUPERGROUP_ID=<ops-supergroup-chat-id>
EMAIL_DIGEST_TOPIC_ID=<topic-id-inbox-email>

OPENCLAW_EXEC_CONTAINER=openclaw-openclaw-gateway-1
OPENCLAW_AGENT_ID=main
OPENCLAW_AGENT_FALLBACK_ID=main
OPENCLAW_AGENT_THINKING=medium
OPENCLAW_AGENT_TIMEOUT_SECONDS=900

REDIS_URL=redis://integration-bus-redis:6379
EMAIL_BRIDGE_PORT=8092
EMAIL_BRIDGE_TOKEN=replace-with-long-random-token
EMAIL_CONTAINER_NAME=agentmail-email-bridge
EMAIL_STATE_VOLUME=agentmail-email-state
EMAIL_STREAM_JOBS=ingest:jobs:email
EMAIL_STREAM_EVENTS=ingest:events:email
EMAIL_STREAM_DLQ=dlq:failed
EMAIL_CONSUMER_GROUP=email-workers
EMAIL_CONSUMER_NAME=agentmail-email-worker
EMAIL_STATUS_KEY=status:email:latest
EMAIL_DIGEST_DISPLAY_NAME=Inbox Email
EMAIL_DIGEST_MORNING_TITLE=Morning brief
EMAIL_DIGEST_INTERVAL_TITLE=Regular digest
EMAIL_DIGEST_EDITORIAL_TITLE=Evening editorial
EMAIL_CRON_MANAGED_PREFIX=AgentMail Inbox
EMAIL_CRON_BRIDGE_LABEL=AgentMail inbox-email bridge
