{
  "inbox_ref": "my-inbox@agentmail.to",
  "topic_name": "inbox-email",
  "timezone": "Europe/Moscow",
  "poll_interval_minutes": 5,
  "scheduler": {
    "enabled": true,
    "tick_seconds": 300
  },
  "poll_bootstrap_lookback_minutes": 720,
  "poll_lag_grace_minutes": 15,
  "digest_bootstrap_lookback_hours": 24,
  "event_retention_days": 7,
  "schedule_slots": ["08:00", "13:00", "16:00", "20:00"],
  "digest_types": {
    "08:00": "morning",
    "13:00": "interval",
    "16:00": "interval",
    "20:00": "editorial"
  },
  "labels": {
    "polled": "benka/polled",
    "low_signal": "benka/low-signal",
    "digested": "benka/digested"
  },
  "low_signal_hints": [
    "newsletter",
    "unsubscribe",
    "sale",
    "discount",
    "promo",
    "digest"
  ]
}
